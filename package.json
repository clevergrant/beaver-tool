{
  "name": "timberborn-tool",
  "description": "Web interface and CLI for controlling Timberborn colonies via the game's HTTP API",
  "private": true,
  "license": "MIT",
  "bin": {
    "beavers": "./build/bin/tb.js"
  },
  "version": "2.0.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:backend": "tsc",
    "build:frontend": "vite build",
    "start": "node build/server.js",
    "dev": "vite --config vite.config.ts",
    "dev:frontend": "vite --config vite.config.ts",
    "dev:backend": "tsc --watch",
    "beavers": "node build/bin/tb.js",
    "build:dist": "node installer/build.js"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.1",
    "sass": "^1.98.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
