{
  "name": "timberborn-tool",
  "description": "Web interface and CLI for controlling Timberborn colonies via the game's HTTP API",
  "private": true,
  "license": "MIT",
  "bin": {
    "tb": "./bin/tb.js"
  },
  "version": "1.1.1",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.frontend.json",
    "build:backend": "tsc",
    "build:frontend": "tsc -p tsconfig.frontend.json",
    "start": "node build/server.js",
    "dev": "npx nodemon --exec \"tsc && node build/server.js\" --ext ts",
    "tb": "node build/bin/tb.js",
    "build:dist": "node installer/build.js"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  }
}
