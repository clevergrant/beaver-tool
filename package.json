{
  "name": "timberborn-tool",
  "description": "Web interface and CLI for controlling Timberborn colonies via the game's HTTP API",
  "private": true,
  "license": "MIT",
  "bin": {
    "beavers": "./build/bin/tb.js"
  },
  "version": "2.0.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && node run-bun.js build-frontend.ts",
    "build:backend": "tsc",
    "build:frontend": "node run-bun.js build-frontend.ts",
    "start": "node build/server.js",
    "dev": "node run-bun.js dev.ts",
    "dev:backend": "tsc --watch",
    "beavers": "node build/bin/tb.js",
    "build:dist": "node run-bun.js installer/build.js"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.1",
    "sass": "^1.98.0",
    "typescript": "^5.9.3"
  }
}
