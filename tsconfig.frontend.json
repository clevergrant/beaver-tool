{
  "compilerOptions": {
    "target": "ES2022",
    "module": "none",
    "outDir": "./public/build",
    "rootDir": "./public",
    "strict": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "sourceMap": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["public/**/*.ts"],
  "exclude": ["public/build"]
}
